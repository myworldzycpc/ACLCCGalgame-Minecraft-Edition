macro nested_macro body=mecha:nested_root:
    with storage agme:args:
        yield body

class RPGCharacter:
    def __init__(self, id, name, pos=None):
        self.id = id
        self.name = name
        self.pos = pos

CHARACTERS = {}

function ./util/rpg_say_effect:
    effect clear @e[tag=character] glowing
    effect give @s glowing infinite 0 true
    playsound entity.villager.ambient master @a ~ ~ ~ 

macro rpg_say character_id=brigadier:string{"type": "word"} content=minecraft:nbt_tag:
    as @n[tag=character,tag=character_id.value] at @s run function ./util/rpg_say_effect
    tellraw @a:
        translate: "%s: %s"
        with:
            - {translate: "%s", with: [(getattr(CHARACTERS[character_id.value], "name", character_id.value))], color: "dark_aqua"}
            - {translate: "%s", with: [content], color: "gray"}

def init_rpg():

    global CHARACTERS

    add_trigger wait_for_continue_trigger menu_option_trigger
    
    next_continue_id = AGMEGlobalScore("next_continue_id")
    next_continue_waiting = AGMEGlobalScore("next_continue_waiting")
    current_action = AGMEGlobalScore("current_action")

    function ./util/wait_for_continue:
        next_continue_id.add()
        store result storage agme:args continue_id int 1:
            next_continue_id.get()
        nested_macro:
            $tellraw @a {translate: "[点击继续]", color: "gray", click_event: {action: "run_command", command: "/trigger wait_for_continue_trigger set $(continue_id)"}}
        next_continue_waiting.set(1)
        scoreboard players reset * wait_for_continue_trigger

    function ./util/wait_for_continue_trigger:
        # say 继续
        next_continue_waiting.set(0)
        function ./util/next_action
    
    function ./util/next_action:
        current_action.add()
        function ./util/replay_action
        
    function ./util/replay_action:
        store result storage agme:args "current_action" int 1:
            current_action.get()
        nested_macro:
            raw ("$function " + ./rpg/dialog + '/$(current_action)')

    function ./rpg/start:
        current_action.set(0)
        function ./util/replay_action

    OPTION_JUMPS = {}

    append function ./init:
        execute function ~/rpg:
            CHARACTERS = {}
            for character_index, character in enumerate(rpg_data["characters"]):
                character_tag = ["character", character['id']]
                trigger_id = ./trigger/player_interacted_with_entity/character + "/" + character['id']
                advancement trigger_id:
                    criteria:
                        player_interacted_with_entity:
                            trigger: "player_interacted_with_entity"
                            conditions:
                                entity:
                                    nbt:
                                        Tags: character_tag
                    rewards:
                        function: trigger_id
                    parent: (./trigger/root)
                function trigger_id:
                    say f"Hello {character['name']}"
                pos = character.get('pos', None)
                if not pos:
                    pos = rpg_data['global_config']['default_pos'].split()
                    pos[0] = str(float(pos[0]) + character_index * 2)
                    pos = " ".join(pos)
                atpos pos:
                    unless entity make_selector(tag=character_tag,type="mannequin"):
                        summon mannequin ~ ~ ~:
                            CustomName: character['name']
                            CustomNameVisible: True
                            Tags: character_tag
                            immovable: True
                    unless entity make_selector(tag=character_tag,type="interaction"):
                        summon interaction ~ ~ ~:
                            Tags: character_tag
                            height: 1.81
                            width: 0.61
                if character['id'] in CHARACTERS:
                    raise ValueError(f"Character {character['id']} already exists")
                CHARACTERS[character['id']] = RPGCharacter(character['id'], character['name'], pos)

            DIALOGS = process.process_dialogs(rpg_data["dialogs"])

            LABELS = {}

            for dialog_index, dialog in enumerate(DIALOGS):
                if 'label' in dialog:
                    if dialog['label'] not in LABELS:
                        LABELS[dialog['label']] = dialog_index
                    else:
                        raise ValueError(f"Dialog {dialog['label']} already exists")

            # say LABELS

            DEFINITIONS = {}
            next_option_id = 1

            for dialog_index, dialog in enumerate(DIALOGS):
                function (./rpg/dialog + '/' + str(dialog_index)):
                    is_wait = 'fallthrough'
                    if isinstance(dialog, str):
                        if dialog == 'stopsound':
                            stopsound @a
                        else:
                            narration dialog
                            is_wait = 'wait'
                    elif isinstance(dialog, dict):
                        if 'define' in dialog:
                            DEFINITIONS.update(dialog['define'])
                        if 'sound' in dialog:
                            playsound dialog['sound'] master @a ~ ~ ~
                        for abbr in DEFINITIONS:
                            if abbr in dialog:
                                rpg_say DEFINITIONS[abbr] dialog[abbr]
                                is_wait = 'wait'
                        for char_id in CHARACTERS:
                            if char_id in dialog:
                                rpg_say char_id dialog[char_id]
                                is_wait = 'wait'
                        if 'narration' in dialog:
                            narration dialog['narration']
                            is_wait = 'wait'
                        if 'no_wait' in dialog and dialog['no_wait']:
                            is_wait = 'fallthrough'
                        if 'menu' in dialog:
                            OPTION_JUMPS[dialog_index] = {}
                            for option in dialog['menu']:
                                for key, value in option.items():
                                    jump_index = LABELS[value]
                                    OPTION_JUMPS[dialog_index][next_option_id] = (jump_index, key)
                                    tellraw @a:
                                        translate: "- %s"
                                        with:
                                            -   translate: "[%s]"
                                                with: [key]
                                                color: "gray"
                                                click_event:
                                                    action: "run_command"
                                                    command: (f"/trigger menu_option_trigger set {next_option_id}")
                                    next_option_id += 1
                            is_wait = 'none'
                        if 'jump' in dialog:
                            label = dialog['jump']
                            if label in LABELS:
                                jump_index = LABELS[label]
                                current_action.set(jump_index)
                                function ./util/replay_action
                                is_wait = 'none'
                            else:
                                raise ValueError(f"Label {label} not found")
                    if is_wait == 'wait':
                        function ./util/wait_for_continue
                    elif is_wait == 'fallthrough':
                        function ./util/next_action

                    
            show_floating_dialog test hi1
            show_floating_dialog test2 hi2

    
    append function ./tick:
        execute function ~/rpg:
            trigger_scb enable wait_for_continue_trigger
            trigger_scb enable menu_option_trigger
            if next_continue_waiting:
                as @a at @s if score @s wait_for_continue_trigger = next_continue_id.name AGME_GLOBAL:
                    return run function ./util/wait_for_continue_trigger
            as @a at @s if score @s menu_option_trigger matches 1..:
                founded = AGMEGlobalScore("founded")
                founded.reset()
                execute function ~/check_founded:
                    for menu_index, options in OPTION_JUMPS.items():
                        if score current_action.name AGME_GLOBAL matches menu_index run return run function ~/menu/{menu_index}:
                            for option_index, jump_info in options.items():
                                if score @s menu_option_trigger matches option_index run return run function (./rpg/option + '/' + str(option_index)):
                                    founded.set(1)
                                    tellraw @a:
                                        translate: "%s 选择了 %s"
                                        with:
                                            -   selector: "@s"
                                            -   translate: "%s"
                                                with: [jump_info[1]]
                                                color: "gray"
                                        color: "gold"
                                    current_action.set(jump_info[0])
                                    function ./util/replay_action
                unless score founded.name AGME_GLOBAL matches 1..:
                    tellraw @s:
                        translate: "你目前尚无法选择这个"
                        color: "red"
                scoreboard players reset * menu_option_trigger



            
def init_other():
    scb_obj_add agme.global

    append function ./init:
        say loaded

    advancement ./trigger/root:
        criteria:
            impossible:
                trigger: "impossible"
    
    append function ./tick:
        advancement revoke @a from ./trigger/root
                
def main():
    init_move_you()
    init_rpg()
    init_other()
    init_scoreboards()

main()

