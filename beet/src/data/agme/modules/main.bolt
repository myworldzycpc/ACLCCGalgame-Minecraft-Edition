import yaml
from contextlib import contextmanager
from mecha import AstSelector, AstSelectorArgument, AstString
import sys
from importlib.util import spec_from_file_location
from importlib.util import module_from_spec

def import_module_from_file(name):
    spec = spec_from_file_location(name, ctx.directory / f"src/data/agme/modules/{name}.py")
    module = module_from_spec(spec)
    spec.loader.exec_module(module)
    return module

process = import_module_from_file("process")

DIRECTIONS = ["left", "right", "forward", "backward"]
ACTIONS = ["jump", "sneak", "sprint"]
DIR_MAP = {forward: (0, 1, 0), backward: (0, -1, 180), left: (1, 0, -90), right: (-1, 0, 90)}

SCOREBOARDS = set()
TRIGGER_LIST = set()

DEBUG = True

macro debug_say message=brigadier:string{"type": "greedy"}:
    if DEBUG:
        say f"[DEBUG] {message.value}"

macro scb_obj_add scb=brigadier:string{"type": "greedy"}:
    for i in scb.value.split():
        SCOREBOARDS.add(i)

macro add_trigger scb=brigadier:string{"type": "greedy"}:
    for i in scb.value.split():
        TRIGGER_LIST.add(i)

macro trigger_scb enable scb=brigadier:string{"type": "word"} selector=minecraft:entity:
    scoreboard players enable selector scb

macro trigger_scb enable scb=brigadier:string{"type": "word"}:
    trigger_scb enable scb @a

with open("src/resources/rpg.yml", 'r', encoding='utf-8') as f:
    rpg_data = yaml.safe_load(f)

for i in DIRECTIONS + ACTIONS:
    predicate (./input + "/" + i):
        condition: "entity_properties"
        entity: "this"
        predicate:
            type_specific:
                type: "player"
                input: ({i: True})

function_tag tick: 
    values: 
        - (./tick)

function_tag load:
    values:
        - (./init)

def init_scoreboards():
    prepend function ./init:
        execute function ~/scoreboards:
            for i in SCOREBOARDS:
                scoreboard objectives add i dummy
            for i in TRIGGER_LIST:
                scoreboard objectives add i trigger

def init_move_you():
    append function ./tick:
        execute function ~/move_you:
            as @a:
                for i in DIRECTIONS:
                    if predicate (./input + "/" + i):
                        # say i
                        as @e[tag=you] at @s:
                            dx = 0.2 * DIR_MAP[i][0]
                            dz = 0.2 * DIR_MAP[i][1]
                            tp ~dx ~ ~dz
                            unless entity @s[tag=no_rotate]:
                                rotate @s ~DIR_MAP[i][2] ~

macro tppos selector=minecraft:entity pos=brigadier:string{"type": "greedy"}:
    pos = pos.value.split()
    if len(pos) == 3:
        tp selector pos[0] pos[1] pos[2]
    elif len(pos) == 5:
        tp selector pos[0] pos[1] pos[2] pos[3] pos[4]
    else:
        raise ValueError("Invalid position format")

macro atpos pos=brigadier:string{"type": "greedy"} body=mecha:nested_root:
    pos = pos.value.split()
    if len(pos) == 3:
        positioned pos[0] pos[1] pos[2]: 
            yield body
    elif len(pos) == 5:
        positioned pos[0] pos[1] pos[2] rotated pos[3] pos[4]: 
            yield body


macro show_floating_dialog character_id=brigadier:string{"type": "word"} content=brigadier:string{"type": "greedy"}:
    as @n[tag=character,tag=character_id.value] at @s:
        say f"[floating_dialog] {content.value[0]}"
        summon block_display ^ ^ ^1:
            block_state: {Name: "tinted_glass"}
            Tags: ["floating_dialog", "background", character_id.value]
        summon text_display ^ ^ ^1.5:
            text: {translate: content}
            Tags: ["floating_dialog", "text", character_id.value]

macro narration text=minecraft:nbt_tag:
    tellraw @a {translate: "%s", color: "dark_gray", with: [text]}

AGME_GLOBAL = "agme.global"

class AGMEGlobalScore():
    def __init__(self, name, enum: dict[str, int] | None = None):
        self.name = name
        self.enum = enum or {}
    
    def add(self, value=1):
        scoreboard players add self.name AGME_GLOBAL value

    def set(self, value):
        scoreboard players set self.name AGME_GLOBAL value

    def get(self):
        scoreboard players get self.name AGME_GLOBAL
    
    def reset(self):
        scoreboard players reset self.name AGME_GLOBAL

    @contextmanager
    def __branch__(self):
        if score self.name AGME_GLOBAL matches 1..:
            yield True

    # def enum(self, value: str | int):
    #     if isinstance(value, str):
    #         return self.enum[value]
    #     elif isinstance(value, int):
    #         for key, val in self.enum.items():
    #             if val == value:
    #                 return key
    #     else:
    #         raise ValueError("Invalid enum value")

def make_selector(var="n", **kwargs):
    args = []
    for key, values in kwargs.items():
        if isinstance(values, list):
            for v in values:
                args.append(AstSelectorArgument(
                    key=AstString(value=key), value=AstString(value=v)
                ))
        else:
            args.append(AstSelectorArgument(
                key=AstString(value=key), value=AstString(value=values)
            ))
    return AstSelector(variable=var, arguments=args)

